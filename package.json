{
  "name": "accounting-mentor",
  "version": "1.0.0",
  "private": true,
  "description": "مساعد التفكير المحاسبي التفاعلي - Interactive Accounting Mentor",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next build",
    "cap:add:android": "npx cap add android",
    "cap:sync": "next build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "android:build": "next build && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "android:build:release": "next build && npx cap sync android && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "framer-motion": "^11.11.10",
    "idb": "^8.0.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
